{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/server.ts --format esm --out-dir dist --external jsdom --external jest --external supertest",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage --forceExit",
    "test:security": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/integration/security.test.ts --forceExit",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/integration/ --forceExit",
    "dev": "tsx watch src/server.ts",
    "telegram:poll": "tsx src/scripts/telegram-poll.ts",
    "db:migrate": "node migrate.cjs",
    "db:migrate:reset": "node migrate.cjs --reset",
    "prepare": "husky",
    "lint": "eslint 'src/**/*.ts' --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.3.6",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.10",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "uuid": "^14.0.0",
    "validator": "^13.15.35",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "isomorphic-dompurify": "^3.16.0",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.5",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }

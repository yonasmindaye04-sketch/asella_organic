
# ═══════════════════════════════════════════════════════════════════
# .env.example
# Asella Organic — Environment Configuration Template
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill every value  (NEVER leave placeholders in production)
#   3. Set permissions:  chmod 600 .env
#   4. Never commit:     make sure .env is in .gitignore
#
# GENERATE SECRETS (run in terminal):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ═══════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (MySQL) ─────────────────────────────────────────────────
# On Yegara/DirectAdmin: get these from DirectAdmin → MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Optional: full connection string (used by some ORMs)
# DATABASE_URL=mysql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME

# ── Auth ─────────────────────────────────────────────────────────────
# Must be at least 64 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_128_CHAR_RANDOM_HEX_STRING
REFRESH_TOKEN_SECRET=REPLACE_WITH_DIFFERENT_128_CHAR_RANDOM_HEX_STRING

# ── CORS / Frontend ──────────────────────────────────────────────────
# No trailing slash. Comma-separate multiple origins if needed.
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ── Telegram Bot ─────────────────────────────────────────────────────
# Get BOT_TOKEN from @BotFather on Telegram
# Get Chat IDs from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id
TELEGRAM_DELIVERY_GROUP_ID=your_delivery_group_chat_id
TELEGRAM_VENDOR_CHAT_ID=your_vendor_chat_id

# ── Google Sheets (optional — for order mirroring) ───────────────────
# Leave empty to disable Google Sheets integration
GOOGLE_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Email (Gmail SMTP) ───────────────────────────────────────────────
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# ── File Uploads ─────────────────────────────────────────────────────
# On Yegara: /home/your_cpanel_username/uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ── Data Retention ───────────────────────────────────────────────────
# How many years to keep identifiable customer data
RETENTION_YEARS=2

# ── Initial Admin User (first-time setup only) ───────────────────────
# Used only on first run to seed the superadmin account
ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_FULL_NAME=Super Admin
ADMIN_ROLE=superadmin

# ── Monitoring (optional) ────────────────────────────────────────────
# Leave empty to disable Sentry error tracking
SENTRY_DSN=
